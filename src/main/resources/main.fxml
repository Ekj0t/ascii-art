<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.asciiart.ui.MainController"
            style="-fx-background-color: #1e1e1e;">

    <!-- TOP BAR -->
    <top>
        <HBox spacing="10" style="-fx-padding: 10; -fx-background-color: #2b2b2b;">
            <Button text="Upload" onAction="#handleUpload"/>
            <Button text="Save" onAction="#handleSave"/>
        </HBox>
    </top>

    <!-- LEFT PANEL -->
    <left>
        <VBox spacing="15" style="-fx-padding: 15; -fx-background-color: #252526;">

            <!-- RESOLUTION -->
            <Label text="Resolution" style="-fx-text-fill: #cccccc;"/>
            <HBox spacing="10">
                <Slider fx:id="resolutionSlider" min="50" max="300" value="150" HBox.hgrow="ALWAYS"/>
                <TextField fx:id="resolutionField" prefWidth="60"/>
            </HBox>

            <!-- CONTRAST -->
            <Label text="Contrast" style="-fx-text-fill: #cccccc;"/>
            <HBox spacing="10">
                <Slider fx:id="contrastSlider" min="0.5" max="2.0" value="0.8" HBox.hgrow="ALWAYS"/>
                <TextField fx:id="contrastField" prefWidth="60"/>
            </HBox>

            <!-- BRIGHTNESS -->
            <Label text="Brightness" style="-fx-text-fill: #cccccc;"/>
            <HBox spacing="10">
                <Slider fx:id="brightnessSlider" min="-0.5" max="0.5" value="0" HBox.hgrow="ALWAYS"/>
                <TextField fx:id="brightnessField" prefWidth="60"/>
            </HBox>

            <!-- INVERT -->
            <CheckBox fx:id="invertCheckbox" text="Invert" style="-fx-text-fill: #cccccc;"/>

            <Separator/>

            <!-- ACTIONS -->
            <Button text="Upload" onAction="#handleUpload"/>
            <Button text="Save" onAction="#handleSave"/>
            <Button text="Reset" onAction="#handleReset"/>

        </VBox>
    </left>

    <!-- CENTER (ASCII OUTPUT) -->
    <center>
        <TextArea fx:id="outputArea"
                  wrapText="false"
                  style="
                        -fx-font-family: 'Consolas';
                        -fx-font-size: 8;
                        -fx-control-inner-background: #1e1e1e;
                        -fx-text-fill: #d4d4d4;
                  "/>
    </center>

    <!-- RIGHT (IMAGE PREVIEW) -->
    <right>
        <VBox spacing="10" style="-fx-padding: 15; -fx-background-color: #252526;">

            <Label text="Preview" style="-fx-text-fill: #cccccc;"/>

            <ImageView fx:id="previewImageView"
                       fitWidth="300"
                       preserveRatio="true"/>

        </VBox>
    </right>

</BorderPane>