<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.asciiart.ui.MainController">

    <!-- ================= TOP BAR ================= -->
    <top>
        <HBox spacing="10" styleClass="top-bar">
            <Button text="Upload" onAction="#handleUpload"/>
            <Button text="Save" onAction="#handleSave"/>
        </HBox>
    </top>

    <!-- ================= LEFT PANEL ================= -->
    <left>
        <VBox styleClass="side-panel">

            <!-- Resolution -->
            <Label text="Resolution" styleClass="section-title"/>
            <HBox spacing="8">
                <Slider fx:id="resolutionSlider" min="50" max="300" value="150" HBox.hgrow="ALWAYS"/>
                <TextField fx:id="resolutionField" prefWidth="55"/>
                <Button text="↺" styleClass="reset-btn" onAction="#resetResolution"/>
            </HBox>

            <!-- Contrast -->
            <Label text="Contrast" styleClass="section-title"/>
            <HBox spacing="8">
                <Slider fx:id="contrastSlider" min="0.5" max="2.0" value="0.8" HBox.hgrow="ALWAYS"/>
                <TextField fx:id="contrastField" prefWidth="55"/>
                <Button text="↺" styleClass="reset-btn" onAction="#resetContrast"/>
            </HBox>

            <!-- Brightness -->
            <Label text="Brightness" styleClass="section-title"/>
            <HBox spacing="8">
                <Slider fx:id="brightnessSlider" min="-0.5" max="0.5" value="0" HBox.hgrow="ALWAYS"/>
                <TextField fx:id="brightnessField" prefWidth="55"/>
                <Button text="↺" styleClass="reset-btn" onAction="#resetBrightness"/>
            </HBox>

            <!-- Toggle -->
            <CheckBox fx:id="invertCheckbox" text="Invert"/>

        </VBox>
    </left>

    <!-- ================= CENTER ================= -->
    <center>
        <TextArea fx:id="outputArea" wrapText="false"/>
    </center>

    <!-- ================= RIGHT PANEL ================= -->
    <right>
        <VBox styleClass="side-panel">

            <Label text="Preview" styleClass="section-title"/>

            <StackPane styleClass="preview-box">
                <ImageView fx:id="previewImageView"
                           fitWidth="280"
                           preserveRatio="true"/>
            </StackPane>

        </VBox>
    </right>

</BorderPane>